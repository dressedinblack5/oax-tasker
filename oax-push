#!/usr/bin/env bash
# Push to dev, record SHA
if [ -z "${OAX_RENAMED:-}" ]; then export OAX_RENAMED=1; exec -a oax-push bash "$0" "$@"; fi
set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  echo "Usage: oax-push"
  echo ""
  echo "Push HEAD to dev, record SHA to /tmp/oax-last-sha."
  echo ""
  echo "Environment:"
  echo "  OAX_REPO_DIR   Repo path (default: current dir)"
  exit 0
fi

REPO_DIR="${OAX_REPO_DIR:-$(pwd)}"
cd "$REPO_DIR"

COMMIT_SHA=$(git rev-parse HEAD)
echo "Pushing $COMMIT_SHA to dev..."

if git push origin dev 2>&1; then
  echo "$COMMIT_SHA" > /tmp/oax-last-sha
  echo "Push succeeded."
else
  echo "Push failed!" >&2
  exit 1
fi
